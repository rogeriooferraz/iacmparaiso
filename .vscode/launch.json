{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "editor-browser",
      "request": "launch",
      "name": "Start Server and Open in Integrated Browser",
      "url": "http://localhost:3000",
      "preLaunchTask": "serve:manual"
    },
    {
      "type": "editor-browser",
      "request": "launch",
      "name": "Open Site in Integrated Browser",
      "url": "http://localhost:3000"
    },
    {
      "type": "editor-browser",
      "request": "attach",
      "name": "Attach to Site in Integrated Browser",
      "urlFilter": "http://localhost:3000/*"
    }
  ]
}
